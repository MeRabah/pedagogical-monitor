generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  professor
  committee
}

enum ComponentType {
  C
  TD
  TP
}

enum ComponentStatus {
  not_started
  in_progress
  completed
  delayed
}

enum AlertSeverity {
  warning
  critical
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  email         String         @unique
  password      String
  role          Role
  createdAt     DateTime       @default(now()) @map("created_at")
  modules       Module[]
  notifications Notification[]

  @@map("users")
}

model Module {
  id           String          @id @default(uuid()) @db.Uuid
  name         String
  academicYear String          @map("academic_year")
  professorId  String?         @map("professor_id") @db.Uuid
  professor    User?           @relation(fields: [professorId], references: [id])
  createdAt    DateTime        @default(now()) @map("created_at")
  components   ModuleComponent[]
  alerts       Alert[]
  reports      ReportModule[]

  @@map("modules")
}

model ModuleComponent {
  id              String          @id @default(uuid()) @db.Uuid
  moduleId        String          @map("module_id") @db.Uuid
  module          Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type            ComponentType
  plannedHours    Int             @map("planned_hours")
  completedHours  Int             @default(0) @map("completed_hours")
  startDate       DateTime?       @map("start_date") @db.Date
  endDate         DateTime?       @map("end_date") @db.Date
  status          ComponentStatus @default(not_started)
  progressLogs    ProgressLog[]

  @@map("module_components")
}

model ProgressLog {
  id          String          @id @default(uuid()) @db.Uuid
  componentId String          @map("component_id") @db.Uuid
  component   ModuleComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  hoursAdded  Int             @map("hours_added")
  logDate     DateTime        @default(now()) @map("log_date") @db.Date

  @@map("progress_logs")
}

model Alert {
  id        String        @id @default(uuid()) @db.Uuid
  moduleId  String        @map("module_id") @db.Uuid
  module    Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  message   String
  severity  AlertSeverity
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("alerts")
}

model Report {
  id          String         @id @default(uuid()) @db.Uuid
  title       String
  content     String
  meetingDate DateTime       @map("meeting_date") @db.Date
  createdAt   DateTime       @default(now()) @map("created_at")
  modules     ReportModule[]

  @@map("reports")
}

model ReportModule {
  reportId String @map("report_id") @db.Uuid
  moduleId String @map("module_id") @db.Uuid
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([reportId, moduleId])
  @@map("report_modules")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
